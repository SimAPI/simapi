{
  "name": "simapi",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "simapi": "bin/simapi.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "lint": "biome lint ./src"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@hono/node-server": "^1.14.0",
    "@libsql/client": "^0.17.2",
    "cac": "^6.7.14",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "pg": "^8.20.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "typescript": "5.9.2"
  }
}
