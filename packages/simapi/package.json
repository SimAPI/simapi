{
  "name": "@simapi/simapi",
  "version": "0.0.6",
  "description": "Build frontend features against real API behavior — before your backend exists.",
  "keywords": [
    "mock",
    "api",
    "server",
    "typescript",
    "development",
    "faker",
    "hono",
    "backend",
    "simulator",
    "zod"
  ],
  "license": "MIT",
  "author": "MayR Labs <info@mayrlabs.com> (https://mayrlabs.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimAPI/simapi.git",
    "directory": "packages/simapi"
  },
  "homepage": "https://simapi.mayrlabs.com",
  "bugs": {
    "url": "https://github.com/SimAPI/simapi/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/SimAPI"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "simapi": "bin/simapi.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "dev": "tsdown --watch",
    "check-types": "tsc --noEmit",
    "lint": "biome lint ./src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@faker-js/faker": "^9.3.0",
    "@hono/node-server": "^1.14.0",
    "@libsql/client": "^0.17.2",
    "cac": "^6.7.14",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "pg": "^8.20.0",
    "tsdown": "^0.21.7",
    "tsx": "^4.19.0",
    "yaml": "^2.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "typescript": "5.9.2",
    "vitest": "^4.1.4"
  }
}
