{
  "name": "@simapi/console",
  "version": "0.0.5",
  "description": "Optional debug console for SimAPI — inspect requests, view schema, and test endpoints interactively.",
  "keywords": [
    "simapi",
    "mock",
    "api",
    "console",
    "debug",
    "react",
    "inspector"
  ],
  "license": "MIT",
  "author": "MayR Labs <info@mayrlabs.com> (https://mayrlabs.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimAPI/simapi.git",
    "directory": "packages/console"
  },
  "homepage": "https://simapi.mayrlabs.com",
  "bugs": {
    "url": "https://github.com/SimAPI/simapi/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/SimAPI"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsdown",
    "prepublishOnly": "npm run build",
    "dev": "vite",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hono/node-server": "^1.x",
    "hono": "^4.x"
  },
  "devDependencies": {
    "@hono/node-server": "^1.14.0",
    "@repo/typescript-config": "*",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "hono": "^4.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^4.0.0",
    "tsdown": "^0.21.7",
    "typescript": "5.9.2",
    "vite": "^5.0.0"
  }
}
