{
  "name": "simapi",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SimAPI/simapi.git"
  },
  "homepage": "https://simapi.mayrlabs.com",
  "scripts": {
    "build": "turbo run build",
    "changelog:sync": "cp packages/console/CHANGELOG.md apps/docs/changelog/console.md && cp packages/simapi/CHANGELOG.md apps/docs/changelog/simapi.md",
    "dev": "turbo run dev",
    "pkg:dev": "turbo run pkg:dev",
    "app:dev": "turbo run app:dev",
    "serve": "turbo run serve",
    "app:serve": "turbo run app:serve",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "release": "npx changeset publish",
    "prepare": "husky",
    "cook": "npm run format && npm run lint && npm run changelog:sync && npm run check && npm install && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched",
      "biome lint --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
